# LinkedIn Auto-Poster — Environment Variables
# Copy this file to .env and fill in your values.
#
# In GitHub Actions, set these as repository secrets instead.

# === REQUIRED ===

# LinkedIn OAuth credentials (from LinkedIn Developer Portal → your app → Auth tab)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# LinkedIn access token (obtained via scripts/linkedin_setup.py)
# Expires every ~60 days. See README.md "Token Renewal" for how to refresh.
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# GitHub API token — used for GitHub Releases monitoring and repo detection.
# Also supports the alias GH_TOKEN (checked as fallback in code).
# In GitHub Actions, the built-in GITHUB_TOKEN is used automatically.
GITHUB_TOKEN=ghp_your_token_here

# === OPTIONAL ===

# LinkedIn refresh token (only available for certain LinkedIn app tiers).
# If set, the client will auto-refresh expired access tokens.
# LINKEDIN_REFRESH_TOKEN=your_refresh_token_here

# GitHub username for repo monitoring (the draft-repo command).
# Fallback: GITHUB_ACTOR (set automatically in GitHub Actions).
# Recommended: set this explicitly for local development.
# GITHUB_USER=your-github-username

# Override author name used in AI prompts (default: from config.yaml author_name)
# AUTHOR_NAME=Your Name


# Copilot SDK authentication (required for AI draft generation)
# Create a fine-grained PAT with Copilot Requests permission
# See README for detailed setup steps
COPILOT_GITHUB_TOKEN=your_fine_grained_pat_here
